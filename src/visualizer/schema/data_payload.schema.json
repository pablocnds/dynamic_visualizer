{
  "title": "Visualizer Data Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["data"],
  "properties": {
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
        "enum": ["series", "table", "ranges", "range"],
          "description": "Optional data kind hint; defaults to auto-detection"
        },
        "x_label": {
          "type": "string",
          "description": "Optional axis label for x-axis"
        },
        "y_label": {
          "type": "string",
          "description": "Optional axis label for y-axis"
        },
        "x_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Values plotted along the X-axis (any ordered domain)"
        },
        "y_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          },
          "description": "Optional values plotted along the Y-axis (dependent measurements)"
        },
        "column_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Column labels for table data"
        },
        "row_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Row labels for table data"
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array"
          },
          "description": "Row-major table cell values"
        },
        "ranges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          },
          "description": "Range pairs along the X-axis, each as [start, end]"
        }
      },
      "allOf": [
        {
          "anyOf": [
            { "required": ["x_axis"] },
            { "required": ["column_names", "row_names", "content"] },
            { "required": ["ranges"] }
          ]
        }
      ]
    }
  }
}
