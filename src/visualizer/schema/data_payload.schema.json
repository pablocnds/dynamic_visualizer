{
  "title": "Visualizer Data Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["data"],
  "properties": {
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
        "enum": ["series", "table", "ranges", "range"],
          "description": "Optional data kind hint; defaults to auto-detection"
        },
        "x_label": {
          "type": "string",
          "description": "Optional axis label for x-axis"
        },
        "y_label": {
          "type": "string",
          "description": "Optional axis label for y-axis"
        },
        "x_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Values plotted along the X-axis (any ordered domain)"
        },
        "y_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          },
          "description": "Optional values plotted along the Y-axis (dependent measurements)"
        },
        "column_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Column labels for table data"
        },
        "column_headers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/tableColumnHeader"
          },
          "description": "Optional grouped table header metadata. Leaf columns are flattened from this structure."
        },
        "row_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Row labels for table data"
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array"
          },
          "description": "Row-major table cell values"
        },
        "table_title": {
          "type": "string",
          "description": "Optional compact title displayed above table views"
        },
        "table_style": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "global": {
              "$ref": "#/$defs/tableColorRule"
            },
            "rows": {
              "type": "array",
              "items": {
                "anyOf": [
                  { "$ref": "#/$defs/tableColorRule" },
                  { "type": "null" }
                ]
              }
            },
            "columns": {
              "type": "array",
              "items": {
                "anyOf": [
                  { "$ref": "#/$defs/tableColorRule" },
                  { "type": "null" }
                ]
              }
            }
          },
          "description": "Optional table color configuration: global plus row/column overrides"
        },
        "ranges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "number"
            }
          },
          "description": "Range pairs along the X-axis, each as [start, end]"
        },
        "range_info": {
          "type": "array",
          "items": {},
          "description": "Optional per-range hover information. Must match the number of ranges."
        }
      },
      "allOf": [
        {
          "anyOf": [
            { "required": ["x_axis"] },
            { "required": ["column_names", "row_names", "content"] },
            { "required": ["column_headers", "row_names", "content"] },
            { "required": ["ranges"] }
          ]
        }
      ]
    }
  },
  "$defs": {
    "tableColumnHeader": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": ["number", "string"]
        },
        "subcolumns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          }
        }
      }
    },
    "tableColorRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "palette": { "type": "string" },
        "reverse": {
          "type": "boolean",
          "description": "Optional flag to flip the palette direction for numeric table values"
        },
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      }
    }
  }
}
