{
  "title": "Visualizer Data Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["data"],
  "properties": {
    "data": {
      "type": "object",
      "additionalProperties": true,
      "required": ["x_axis", "y_axis"],
      "properties": {
        "x_label": {
          "type": "string",
          "description": "Optional axis label for x-axis"
        },
        "y_label": {
          "type": "string",
          "description": "Optional axis label for y-axis"
        },
        "x_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["number", "string"]
          },
          "description": "Values plotted along the X-axis (any ordered domain)"
        },
        "y_axis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          },
          "description": "Values plotted along the Y-axis (dependent measurements)"
        }
      }
    }
  }
}
